extends layout

block content
  main.landing-page
    section.hero
      .hero-text 
        p.eyebrow Family-owned since 1992
        h1 Downtown Donuts
        p.hero-tagline Cozy donuts, fresh coffee, and downtown charm.

        .hero-buttons
          a.button.primary(href='/menu') View Menu 
          a.button.secondary(href='https://www.doordash.com/' target='_blank') Order Online

      .hero-card 
        h2 Fresh every morning 
        p Stop by for handmade donuts, warm coffee, and a welcoming atmosphere.

    section.home-preview 
      article.preview-card 
        h2 Our Menu 
        p Explore donuts, coffee, and seasonal favorites.
        a(href='/menu') See the menu 

      article.preview-card 
        h2 Our Story 
        p Learn more about our family-owned shop and downtown history 
        a(href='/about') About us 

      article.preview-card 
        h2 Customer Comments 
        p Read what visitors are saying or leave your own comment.
        a(href='/comments') View comments 

